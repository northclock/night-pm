{
  "name": "night-pm",
  "productName": "Night PM",
  "version": "0.1.0",
  "description": "A brainless product management app that sits on top of AI engines. Manage thoughts, todos, calendar, contacts, and documents -- all as plain files, all through MCP tools.",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "vitest run",
    "test:gemini": "vitest run src/test/gemini.test.ts",
    "test:codex": "vitest run src/test/codex.test.ts",
    "test:claude": "vitest run src/test/claude.test.ts",
    "test:opencode": "vitest run src/test/opencode.test.ts",
    "test:watch": "vitest",
    "reset": "rm -f \"$HOME/Library/Application Support/Night PM/night-pm-settings.json\" && node scripts/clear-keychain.mjs && echo 'Night PM settings cleared.'"
  },
  "keywords": [],
  "author": {
    "name": "lurose5",
